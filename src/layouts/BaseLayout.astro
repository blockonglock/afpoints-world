---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AF.POINTS',
  description = 'AF.POINTS: music, tools, notes, and plugins.',
} = Astro.props;

const pageTitle = title === 'AF.POINTS' ? title : `${title} / AF.POINTS`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <SiteHeader />
    <main class="page-shell">
      <slot />
    </main>
  </body>
</html>
