---
import BaseLayout from '../layouts/BaseLayout.astro';
import reviews from '../data/reviews.json';

const updates = [
  ...reviews.slice(0, 6).map((review) => ({
    date: review.year ? String(review.year) : 'review',
    text: `${review.artist} - ${review.title}`,
    href: `/review/${review.slug}/`,
  })),
  { date: 'index', text: 'all reviews', href: '/review/' },
];
---

<BaseLayout>
  <section class="feed" aria-label="AF.POINTS updates">
    {
      updates.map((item) => (
        <article class="feed-item">
          <time>{item.date}</time>
          <a href={item.href}>{item.text}</a>
        </article>
      ))
    }
  </section>
</BaseLayout>
